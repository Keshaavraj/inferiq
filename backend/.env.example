GROQ_API_KEY=your_groq_api_key_here

# Langfuse (https://cloud.langfuse.com - free tier)
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com

# Arize Phoenix (self-hosted on Railway)
PHOENIX_HOST=0.0.0.0
PHOENIX_PORT=6006
# Set this when Phoenix runs as a separate Railway service:
# PHOENIX_COLLECTOR_ENDPOINT=https://your-phoenix-service.railway.app/v1/traces

# App
ENVIRONMENT=development
DATABASE_PATH=./inferiq.db
